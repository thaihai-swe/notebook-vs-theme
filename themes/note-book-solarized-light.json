    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#93a1a1",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "keyword.control",
                "keyword.operator.new"
            ],
            "settings": {
                "foreground": "#859900"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "meta.function-call",
                "support.function"
            ],
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#cb4b16"
            }
        },
        {
            "scope": [
                "support.function.builtin",
                "variable.language.builtin",
                "support.class.builtin"
            ],
            "settings": {
                "foreground": "#cb4b16"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.character"
            ],
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other"
            ],
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": [
                "variable.language",
                "variable.parameter"
            ],
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": [
                "support.constant",
                "constant.other"
            ],
            "settings": {
                "foreground": "#b58900"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "punctuation"
            ],
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "meta.tag"
            ],
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#586e75"
            }
        },
        {
            "scope": [
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "scope": [
                "meta.property-value",
                "support.constant.property-value"
            ],
            "settings": {
                "foreground": "#b58900"
            }
        },
        {
            "scope": [
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#657b83"
            }
        },
        {
            "scope": [
                "support.variable",
                "variable.language.this"
            ],
            "settings": {
                "foreground": "#cb4b16"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#268bd2"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#657b83",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.underline.link",
                "markup.underline"
            ],
            "settings": {
                "foreground": "#268bd2",
                "fontStyle": "underline"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#2aa198"
            }
        },
        {
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#dc322f"
            }
        },
        {
            "name": "JSON Keys",
            "scope": [
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "name": "YAML Keys",
            "scope": [
                "entity.name.tag.yaml"
            ],
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "name": "Markdown Blockquotes",
            "scope": [
                "markup.quote",
                "punctuation.definition.quote.markdown"
            ],
            "settings": {
                "foreground": "#93a1a1",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markdown List Markers",
            "scope": [
                "markup.list",
                "punctuation.definition.list_item.markdown"
            ],
            "settings": {
                "foreground": "#b58900"
            }
        },
        {
            "name": "CSS Properties",
            "scope": [
                "support.type.property-name.css",
                "support.type.property-name.media"
            ],
            "settings": {
                "foreground": "#d33682"
            }
        },
        {
            "name": "CSS Selectors",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css"
            ],
            "settings": {
                "foreground": "#268bd2"
            }
        },
        {
            "name": "CSS Units",
            "scope": [
                "keyword.other.unit"
            ],
            "settings": {
                "foreground": "#d33682"
            }
        }
    ]
}
