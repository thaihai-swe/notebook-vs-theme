{
    "name": "Note Book Solarized Light",
    "type": "light",
    "semanticHighlighting": true,
    "semanticTokenColors": {
        "function": "#268bd2",
        "function.declaration": "#268bd2",
        "method": "#268bd2",
        "method.declaration": "#268bd2",
        "class": "#cb4b16",
        "interface": "#cb4b16",
        "type": "#cb4b16",
        "parameter": "#657b83",
        "variable": "#657b83",
        "variable.readonly": "#b58900",
        "variable.declaration": "#657b83",
        "property": "#d33682",
        "property.declaration": "#d33682",
        "property.readonly": "#d33682",
        "namespace": "#cb4b16",
        "enumMember": "#cb4b16",
        "typeParameter": "#cb4b16",
        "decorator": "#b58900",
        "macro": {
            "foreground": "#268bd2",
            "fontStyle": "bold"
        },
        "string": "#2aa198",
        "number": "#d33682",
        "keyword": "#859900",
        "comment": {
            "foreground": "#93a1a1",
            "fontStyle": "italic"
        },
        "regexp": "#dc322f"
    },
