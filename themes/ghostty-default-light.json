    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#696c77",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#4078f2",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword.control",
                "keyword.operator.new"
            ],
            "settings": {
                "foreground": "#4078f2",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "meta.function-call",
                "support.function"
            ],
            "settings": {
                "foreground": "#a626a4"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#ca1243"
            }
        },
        {
            "scope": [
                "support.function.builtin",
                "variable.language.builtin",
                "support.class.builtin"
            ],
            "settings": {
                "foreground": "#e45649"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#50a14f"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.character"
            ],
            "settings": {
                "foreground": "#c18401"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other"
            ],
            "settings": {
                "foreground": "#474965"
            }
        },
        {
            "scope": [
                "variable.language",
                "variable.parameter"
            ],
            "settings": {
                "foreground": "#a626a4"
            }
        },
        {
            "scope": [
                "support.constant",
                "constant.other"
            ],
            "settings": {
                "foreground": "#c18401"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "punctuation"
            ],
            "settings": {
                "foreground": "#4f525d"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "meta.tag"
            ],
            "settings": {
                "foreground": "#4078f2"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#a626a4"
            }
        },
        {
            "scope": [
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#474965"
            }
        },
        {
            "scope": [
                "meta.property-value",
                "support.constant.property-value"
            ],
            "settings": {
                "foreground": "#c18401"
            }
        },
        {
            "scope": [
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#c18401"
            }
        },
        {
            "scope": [
                "support.variable",
                "variable.language.this"
            ],
            "settings": {
                "foreground": "#e45649"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "foreground": "#4078f2",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#474965",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.underline.link",
                "markup.underline"
            ],
            "settings": {
                "foreground": "#4078f2",
                "fontStyle": "underline"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#50a14f"
            }
        },
        {
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#e45649"
            }
        },
        {
            "name": "JSON Keys",
            "scope": [
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#474965"
            }
        },
        {
            "name": "YAML Keys",
            "scope": [
                "entity.name.tag.yaml"
            ],
            "settings": {
                "foreground": "#4078f2"
            }
        },
        {
            "name": "Markdown Blockquotes",
            "scope": [
                "markup.quote",
                "punctuation.definition.quote.markdown"
            ],
            "settings": {
                "foreground": "#696c77",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markdown List Markers",
            "scope": [
                "markup.list",
                "punctuation.definition.list_item.markdown"
            ],
            "settings": {
                "foreground": "#c18401"
            }
        },
        {
            "name": "CSS Properties",
            "scope": [
                "support.type.property-name.css",
                "support.type.property-name.media"
            ],
            "settings": {
                "foreground": "#474965"
            }
        },
        {
            "name": "CSS Selectors",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css"
            ],
            "settings": {
                "foreground": "#a626a4"
            }
        },
        {
            "name": "CSS Units",
            "scope": [
                "keyword.other.unit"
            ],
            "settings": {
                "foreground": "#c18401"
            }
        }
    ]
}