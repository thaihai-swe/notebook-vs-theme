  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8c8a8e",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1462a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#1462a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#7f5eb5"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#2f7d5b"
      }
    },
    {
      "scope": [
        "support.function.builtin",
        "variable.language.builtin",
        "support.class.builtin"
      ],
      "settings": {
        "foreground": "#bf4355"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#2f7d5b"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#ab5a00",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#474965"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#7f5eb5"
      }
    },
    {
      "scope": [
        "support.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#737074"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#1462a4"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7f5eb5"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#474965"
      }
    },
    {
      "scope": [
        "meta.property-value",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    },
    {
      "scope": [
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    },
    {
      "scope": [
        "support.variable",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#bf4355"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#1462a4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#474965",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline"
      ],
      "settings": {
        "foreground": "#1462a4",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#2f7d5b"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#bf4355"
      }
    }
  ]
}