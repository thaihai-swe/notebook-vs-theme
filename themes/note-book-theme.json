  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#787570",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#1462a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#1462a4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#6d4da5"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b4637a"
      }
    },
    {
      "scope": [
        "support.function.builtin",
        "variable.language.builtin",
        "support.class.builtin"
      ],
      "settings": {
        "foreground": "#bf4355"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#2f7d5b"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#474965"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#6d4da5"
      }
    },
    {
      "scope": [
        "support.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#676460"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#1462a4"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#6d4da5"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#474965"
      }
    },
    {
      "scope": [
        "meta.property-value",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    },
    {
      "scope": [
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    },
    {
      "scope": [
        "support.variable",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#bf4355"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#1462a4",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#474965",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline"
      ],
      "settings": {
        "foreground": "#1462a4",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#2f7d5b"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#bf4355"
      }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#474965"
      }
    },
    {
      "name": "YAML Keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#1462a4"
      }
    },
    {
      "name": "Markdown Blockquotes",
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.markdown"
      ],
      "settings": {
        "foreground": "#787570",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown List Markers",
      "scope": [
        "markup.list",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.media"
      ],
      "settings": {
        "foreground": "#474965"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#6d4da5"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#ab5a00"
      }
    }
  ]
}