{
  "name": "Note Book Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#ab97c3",
    "method": "#ab97c3",
    "class": "#bf8d9c",
    "interface": "#bf8d9c",
    "type": "#bf8d9c",
    "parameter": "#c5beb3",
    "variable.readonly": "#cb7c7a"
  },
  "colors": {
    "editor.background": "#1f1b18",
    "editor.foreground": "#d7cfc5",
    "editorLineNumber.foreground": "#5a534c",
    "editorLineNumber.activeForeground": "#d7cfc5",
    "editorCursor.foreground": "#cb7c7a",
    "editor.lineHighlightBackground": "#2a2522",
    "editorWhitespace.foreground": "#4c443e",
    "editorGroupHeader.tabsBackground": "#181513",
    "editorGroup.border": "#2a2522",
    "tab.activeBackground": "#1f1b18",
    "tab.activeForeground": "#d7cfc5",
    "tab.inactiveBackground": "#181513",
    "tab.inactiveForeground": "#857c74",
    "tab.border": "#1c1917",
    "activityBar.background": "#181513",
    "activityBar.foreground": "#d7cfc5",
    "activityBar.inactiveForeground": "#857c74",
    "activityBar.border": "#1c1917",
    "activityBarBadge.background": "#b88d6f",
    "activityBarBadge.foreground": "#181513",
    "sideBar.background": "#181513",
    "sideBar.foreground": "#d7cfc5",
    "sideBar.border": "#1c1917",
    "sideBarTitle.foreground": "#d7cfc5",
    "sideBarSectionHeader.background": "#1c1917",
    "sideBarSectionHeader.foreground": "#d7cfc5",
    "list.activeSelectionBackground": "#2f2722",
    "list.activeSelectionForeground": "#d7cfc5",
    "list.inactiveSelectionBackground": "#28211d",
    "list.hoverBackground": "#28211d80",
    "list.focusBackground": "#2f2722",
    "list.highlightForeground": "#b88d6f",
    "statusBar.background": "#181513",
    "statusBar.foreground": "#d7cfc5",
    "statusBar.border": "#1c1917",
    "statusBar.debuggingBackground": "#cb7c7a",
    "statusBar.debuggingForeground": "#181513",
    "statusBar.noFolderBackground": "#181513",
    "titleBar.activeBackground": "#181513",
    "titleBar.activeForeground": "#d7cfc5",
    "titleBar.inactiveBackground": "#181513",
    "titleBar.inactiveForeground": "#857c74",
    "titleBar.border": "#1c1917",
    "input.background": "#1f1b18",
    "input.foreground": "#d7cfc5",
    "input.border": "#2a2522",
    "input.placeholderForeground": "#857c74",
    "button.background": "#b88d6f",
    "button.foreground": "#181513",
    "button.hoverBackground": "#b88d6fcc",
    "badge.background": "#b88d6f",
    "badge.foreground": "#181513",
    "panel.background": "#181513",
    "panel.border": "#1c1917",
    "panelTitle.activeBorder": "#b88d6f",
    "panelTitle.activeForeground": "#d7cfc5",
    "panelTitle.inactiveForeground": "#857c74",
    "terminal.background": "#181513",
    "terminal.foreground": "#d7cfc5",
    "terminal.ansiBlack": "#1f1b18",
    "terminal.ansiRed": "#cb7c7a",
    "terminal.ansiGreen": "#89a58b",
    "terminal.ansiYellow": "#cfa574",
    "terminal.ansiBlue": "#93a2b5",
    "terminal.ansiMagenta": "#ab97c3",
    "terminal.ansiCyan": "#8aa18f",
    "terminal.ansiWhite": "#d7cfc5",
    "gitDecoration.modifiedResourceForeground": "#cfa574",
    "gitDecoration.deletedResourceForeground": "#cb7c7a",
    "gitDecoration.untrackedResourceForeground": "#89a58b",
    "gitDecoration.ignoredResourceForeground": "#857c74",
    "gitDecoration.conflictingResourceForeground": "#ab97c3",
    "editorWidget.background": "#181513",
    "editorWidget.border": "#2a2522",
    "editor.selectionBackground": "#423832",
    "editor.selectionHighlightBackground": "#42383280",
    "editor.findMatchBackground": "#cfa57440",
    "editor.findMatchHighlightBackground": "#cfa57420",
    "editorIndentGuide.background": "#3c352f",
    "editorIndentGuide.activeBackground": "#5a534c",
    "scrollbar.shadow": "#18151360",
    "scrollbarSlider.background": "#857c7444",
    "scrollbarSlider.hoverBackground": "#857c7466",
    "scrollbarSlider.activeBackground": "#b88d6f88",
    "minimap.background": "#1f1b18"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#857c74",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#b88d6f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#b88d6f",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "support.function"
      ],
      "settings": {
        "foreground": "#ab97c3"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#bf8d9c"
      }
    },
    {
      "scope": [
        "support.function.builtin",
        "variable.language.builtin",
        "support.class.builtin"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#89a58b"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#d7cfc5"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#c5beb3"
      }
    },
    {
      "scope": [
        "support.constant",
        "constant.other"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#a59d95"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#b88d6f"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#ab97c3"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#c5beb3"
      }
    },
    {
      "scope": [
        "meta.property-value",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    },
    {
      "scope": [
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    },
    {
      "scope": [
        "support.variable",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#b88d6f",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#d7cfc5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline"
      ],
      "settings": {
        "foreground": "#ab97c3",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#89a58b"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#b88d6f"
      }
    },
    {
      "name": "YAML Keys",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#b88d6f"
      }
    },
    {
      "name": "Markdown Blockquotes",
      "scope": [
        "markup.quote",
        "punctuation.definition.quote.markdown"
      ],
      "settings": {
        "foreground": "#857c74",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown List Markers",
      "scope": [
        "markup.list",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.media"
      ],
      "settings": {
        "foreground": "#c5beb3"
      }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#ab97c3"
      }
    },
    {
      "name": "CSS Units",
      "scope": [
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#cb7c7a"
      }
    }
  ]
}
