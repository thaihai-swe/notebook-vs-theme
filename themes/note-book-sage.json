    "tokenColors": [
        {
            "scope": [
                "comment",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#9893a5",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword",
                "storage.type",
                "storage.modifier"
            ],
            "settings": {
                "foreground": "#907aa9",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "keyword.control",
                "keyword.operator.new"
            ],
            "settings": {
                "foreground": "#907aa9",
                "fontStyle": "italic"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "meta.function-call",
                "support.function"
            ],
            "settings": {
                "foreground": "#286983"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "support.type",
                "support.class"
            ],
            "settings": {
                "foreground": "#d7827e"
            }
        },
        {
            "scope": [
                "support.function.builtin",
                "variable.language.builtin",
                "support.class.builtin"
            ],
            "settings": {
                "foreground": "#d7827e"
            }
        },
        {
            "scope": [
                "string",
                "string.quoted"
            ],
            "settings": {
                "foreground": "#56949f"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "constant.language",
                "constant.character"
            ],
            "settings": {
                "foreground": "#ea9d34"
            }
        },
        {
            "scope": [
                "variable",
                "variable.other"
            ],
            "settings": {
                "foreground": "#575279"
            }
        },
        {
            "scope": [
                "variable.language",
                "variable.parameter"
            ],
            "settings": {
                "foreground": "#575279"
            }
        },
        {
            "scope": [
                "support.constant",
                "constant.other"
            ],
            "settings": {
                "foreground": "#ea9d34"
            }
        },
        {
            "scope": [
                "keyword.operator",
                "punctuation"
            ],
            "settings": {
                "foreground": "#907aa9"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "meta.tag"
            ],
            "settings": {
                "foreground": "#907aa9"
            }
        },
        {
            "scope": [
                "entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#286983"
            }
        },
        {
            "scope": [
                "support.type.property-name"
            ],
            "settings": {
                "foreground": "#d7827e"
            }
        },
        {
            "scope": [
                "meta.property-value",
                "support.constant.property-value"
            ],
            "settings": {
                "foreground": "#ea9d34"
            }
        },
        {
            "scope": [
                "variable.other.constant"
            ],
            "settings": {
                "foreground": "#575279"
            }
        },
        {
            "scope": [
                "support.variable",
                "variable.language.this"
            ],
            "settings": {
                "foreground": "#575279"
            }
        },
        {
            "scope": [
                "markup.heading"
            ],
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.bold"
            ],
            "settings": {
                "foreground": "#474965",
                "fontStyle": "bold"
            }
        },
        {
            "scope": [
                "markup.underline.link",
                "markup.underline"
            ],
            "settings": {
                "foreground": "#907aa9",
                "fontStyle": "underline"
            }
        },
        {
            "scope": [
                "markup.inline.raw",
                "markup.fenced_code"
            ],
            "settings": {
                "foreground": "#286983"
            }
        },
        {
            "scope": [
                "invalid",
                "invalid.illegal"
            ],
            "settings": {
                "foreground": "#8d0003"
            }
        },
        {
            "name": "JSON Keys",
            "scope": [
                "support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#d7827e"
            }
        },
        {
            "name": "YAML Keys",
            "scope": [
                "entity.name.tag.yaml"
            ],
            "settings": {
                "foreground": "#907aa9"
            }
        },
        {
            "name": "Markdown Blockquotes",
            "scope": [
                "markup.quote",
                "punctuation.definition.quote.markdown"
            ],
            "settings": {
                "foreground": "#9893a5",
                "fontStyle": "italic"
            }
        },
        {
            "name": "Markdown List Markers",
            "scope": [
                "markup.list",
                "punctuation.definition.list_item.markdown"
            ],
            "settings": {
                "foreground": "#ea9d34"
            }
        },
        {
            "name": "CSS Properties",
            "scope": [
                "support.type.property-name.css",
                "support.type.property-name.media"
            ],
            "settings": {
                "foreground": "#d7827e"
            }
        },
        {
            "name": "CSS Selectors",
            "scope": [
                "entity.other.attribute-name.class.css",
                "entity.other.attribute-name.id.css"
            ],
            "settings": {
                "foreground": "#286983"
            }
        },
        {
            "name": "CSS Units",
            "scope": [
                "keyword.other.unit"
            ],
            "settings": {
                "foreground": "#907aa9"
            }
        }
    ]
}
