    "tokenColors": [
        {"scope": ["comment", "punctuation.definition.comment"], "settings": {"foreground": "#6e6a86", "fontStyle": "italic"}},
        {"scope": ["keyword", "storage.type", "storage.modifier"], "settings": {"foreground": "#3e8fb0", "fontStyle": "italic"}},
        {"scope": ["keyword.control", "keyword.operator.new"], "settings": {"foreground": "#3e8fb0", "fontStyle": "italic"}},
        {"scope": ["entity.name.function", "meta.function-call", "support.function"], "settings": {"foreground": "#3e8fb0"}},
        {"scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"], "settings": {"foreground": "#9ccfd8"}},
        {"scope": ["support.function.builtin", "variable.language.builtin", "support.class.builtin"], "settings": {"foreground": "#9ccfd8"}},
        {"scope": ["string", "string.quoted"], "settings": {"foreground": "#f6c177"}},
        {"scope": ["constant.numeric", "constant.language", "constant.character"], "settings": {"foreground": "#ea9a97"}},
        {"scope": ["variable", "variable.other"], "settings": {"foreground": "#e0def4"}},
        {"scope": ["variable.language", "variable.parameter"], "settings": {"foreground": "#e0def4"}},
        {"scope": ["support.constant", "constant.other"], "settings": {"foreground": "#f6c177"}},
        {"scope": ["keyword.operator", "punctuation"], "settings": {"foreground": "#908caa"}},
        {"scope": ["entity.name.tag", "meta.tag"], "settings": {"foreground": "#908caa"}},
        {"scope": ["entity.other.attribute-name"], "settings": {"foreground": "#3e8fb0"}},
        {"scope": ["support.type.property-name"], "settings": {"foreground": "#ea9a97"}},
        {"scope": ["meta.property-value", "support.constant.property-value"], "settings": {"foreground": "#f6c177"}},
        {"scope": ["variable.other.constant"], "settings": {"foreground": "#e0def4"}},
        {"scope": ["support.variable", "variable.language.this"], "settings": {"foreground": "#e0def4"}},
        {"scope": ["markup.heading"], "settings": {"fontStyle": "bold"}},
        {"scope": ["markup.bold"], "settings": {"foreground": "#e0def4", "fontStyle": "bold"}},
        {"scope": ["markup.underline.link", "markup.underline"], "settings": {"foreground": "#9ccfd8", "fontStyle": "underline"}},
        {"scope": ["markup.inline.raw", "markup.fenced_code"], "settings": {"foreground": "#3e8fb0"}},
        {"scope": ["invalid", "invalid.illegal"], "settings": {"foreground": "#eb6f92"}},
        {"name": "JSON Keys", "scope": ["support.type.property-name.json"], "settings": {"foreground": "#ea9a97"}},
        {"name": "YAML Keys", "scope": ["entity.name.tag.yaml"], "settings": {"foreground": "#908caa"}},
        {"name": "Markdown Blockquotes", "scope": ["markup.quote", "punctuation.definition.quote.markdown"], "settings": {"foreground": "#6e6a86", "fontStyle": "italic"}},
        {"name": "Markdown List Markers", "scope": ["markup.list", "punctuation.definition.list_item.markdown"], "settings": {"foreground": "#f6c177"}},
        {"name": "CSS Properties", "scope": ["support.type.property-name.css", "support.type.property-name.media"], "settings": {"foreground": "#ea9a97"}},
        {"name": "CSS Selectors", "scope": ["entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"], "settings": {"foreground": "#3e8fb0"}},
        {"name": "CSS Units", "scope": ["keyword.other.unit"], "settings": {"foreground": "#908caa"}}
    ]
