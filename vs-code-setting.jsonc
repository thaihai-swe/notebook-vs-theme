// ============================================================================
// VS Code settings.json — Full UI/UX Upgrade
// Purpose: premium, calm, readable, iOS-inspired VS Code workspace.
// Notes:
// - This file is JSONC, not strict JSON. VS Code settings.json supports comments.
// - Keep this as User Settings unless you intentionally want it project-specific.
// - The custom-ui-style.stylesheet section requires your Custom UI Style extension.
// - If a font is not installed, VS Code falls back to the next font in the list.
// ============================================================================
{
    "extensions.allowed": {
        "anthropic.claude-code": false,
        "*": true
    },
    // ======================================================================
    // Tab management
    // ======================================================================
    "workbench.editor.tabActionCloseVisibility": true,
    "workbench.editor.tabActionUnpinVisibility": true,
    // ======================================================================
    // Quick navigation
    // ======================================================================
    "workbench.quickOpen.closeOnFocusLost": true,
    "workbench.quickOpen.preserveInput": true,
    // ======================================================================
    // 1. Window, startup, and focus behavior
    // ----------------------------------------------------------------------
    // Goal: open directly into the workspace, keep Zen Mode useful but not
    // disruptive, and use a custom title bar for the polished UI shell.
    // ======================================================================
    "zenMode.centerLayout": false,
    "zenMode.fullScreen": false,
    "zenMode.hideActivityBar": false,
    "zenMode.hideLineNumbers": false,
    "zenMode.hideStatusBar": false,
    "zenMode.restore": true,
    "workbench.startupEditor": "welcomePage",
    "workbench.iconTheme": "material-icon-theme",
    "window.zoomLevel": 1.0,
    "window.title": "${dirty}${activeEditorShort}${separator}${rootName}${separator}${appName}",
    "window.titleBarStyle": "custom",
    "window.commandCenter": true,
    "workbench.layoutControl.enabled": false,
    "window.restoreWindows": "all",
    // ======================================================================
    // 2. Editor scrollbar and minimap
    // ----------------------------------------------------------------------
    // Goal: keep navigation visible without making the editor feel heavy.
    // Scrollbar sizes are set to 16px and 12px to match custom CSS overrides.
    // ======================================================================
    "editor.scrollbar.vertical": "auto",
    "editor.scrollbar.horizontal": "auto",
    "editor.scrollbar.verticalScrollbarSize": 24,
    "editor.scrollbar.horizontalScrollbarSize": 18,
    "editor.scrollbar.useShadows": true,
    "editor.scrollbar.scrollByPage": true,
    "editor.minimap.enabled": true,
    "editor.minimap.side": "right",
    "editor.minimap.scale": 1,
    "editor.minimap.size": "proportional",
    "editor.minimap.renderCharacters": false,
    "editor.minimap.maxColumn": 120,
    "editor.minimap.showSlider": "always",
    // ======================================================================
    // 3. Editor behavior and typography
    // ----------------------------------------------------------------------
    // Goal: readable long coding sessions. Font size and line height are still
    // large, but slightly calmer than before for better information density.
    // ======================================================================
    "editor.fontFamily": "'IBM Plex Mono', 'JetBrains Mono', 'FiraCode Nerd Font Mono', 'Monaspace Neon', 'Fira Code', 'Menlo', 'Monaco', monospace",
    "editor.fontSize": 15,
    "editor.fontWeight": "400",
    "editor.lineHeight": 1.8,
    "editor.letterSpacing": 0.15,
    "editor.fontLigatures": "'calt', 'liga', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'tnum', 'kern', 'cv11'",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorStyle": "line",
    "editor.cursorBlinking": "smooth",
    "editor.cursorWidth": 2,
    "editor.mouseWheelZoom": true,
    "editor.padding.top": 14,
    "editor.padding.bottom": 18,
    "editor.smoothScrolling": true,
    "editor.scrollBeyondLastColumn": 3,
    "editor.scrollPredominantAxis": true,
    "editor.fastScrollSensitivity": 5,
    "editor.mouseWheelScrollSensitivity": 1,
    "editor.cursorSurroundingLines": 6,
    "editor.scrollBeyondLastLine": false,
    "editor.wordWrap": "off",
    "editor.wrappingIndent": "same",
    "editor.renderLineHighlight": "all",
    "editor.renderFinalNewline": "dimmed",
    "editor.renderWhitespace": "selection",
    "editor.renderControlCharacters": false,
    "editor.copyWithSyntaxHighlighting": false,
    "editor.dragAndDrop": true,
    "editor.stickyTabStops": true,
    "editor.largeFileOptimizations": true,
    "editor.accessibilitySupport": "auto",
    // Formatting and save actions.
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
    },
    // Unicode safety.
    "editor.unicodeHighlight.ambiguousCharacters": true,
    "editor.unicodeHighlight.invisibleCharacters": true,
    "editor.unicodeHighlight.nonBasicASCII": false,
    // ======================================================================
    // 4. Suggestions, hints, hover, and code navigation
    // ======================================================================
    "editor.suggest.preview": true,
    "editor.suggest.previewMode": "prefix",
    "editor.suggest.insertMode": "replace",
    "editor.suggest.matchOnWordStartOnly": false,
    "editor.suggestSelection": "recentlyUsedByPrefix",
    "editor.acceptSuggestionOnCommitCharacter": false,
    "editor.acceptSuggestionOnEnter": "smart",
    "editor.suggest.localityBonus": true,
    "editor.suggest.showStatusBar": true,
    "editor.snippetSuggestions": "top",
    "editor.tabCompletion": "on",
    "editor.quickSuggestions": {
        "other": true,
        "comments": true,
        "strings": true
    },
    "editor.inlineSuggest.enabled": true,
    "editor.inlineSuggest.showToolbar": "onHover",
    "editor.inlineSuggest.suppressSuggestions": false,
    "editor.parameterHints.enabled": true,
    "editor.parameterHints.cycle": true,
    "editor.linkedEditing": true,
    "editor.hover.enabled": "on",
    "editor.hover.delay": 350,
    "editor.hover.sticky": true,
    "editor.codeLens": true,
    "editor.codeLensFontFamily": "'IBM Plex Mono', 'JetBrains Mono', 'Monaspace Neon', 'Fira Code', 'Menlo', 'Monaco', monospace",
    "editor.codeLensFontSize": 13,
    "editor.inlayHints.enabled": "onUnlessPressed",
    "editor.inlayHints.fontSize": 14,
    "editor.inlayHints.padding": true,
    "editor.inlayHints.maximumLength": 40,
    // ======================================================================
    // 5. Indent guides, bracket guides, and sticky scroll
    // ======================================================================
    "editor.guides.indentation": true,
    "editor.guides.highlightActiveIndentation": "always",
    "editor.guides.bracketPairs": "active",
    "editor.guides.bracketPairsHorizontal": true,
    "editor.guides.highlightActiveBracketPair": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
    "editor.stickyScroll.enabled": true,
    "editor.stickyScroll.maxLineCount": 4,
    // ======================================================================
    // 6. Breadcrumbs
    // ======================================================================
    "breadcrumbs.enabled": true,
    "breadcrumbs.filePath": "on",
    "breadcrumbs.symbolPath": "on",
    "breadcrumbs.icons": true,
    "breadcrumbs.showArrays": true,
    "breadcrumbs.showBooleans": true,
    "breadcrumbs.showClasses": true,
    "breadcrumbs.showConstants": true,
    "breadcrumbs.showConstructors": true,
    "breadcrumbs.showEnumMembers": true,
    "breadcrumbs.showEnums": true,
    "breadcrumbs.showFields": true,
    "breadcrumbs.showFiles": true,
    "breadcrumbs.showFunctions": true,
    "breadcrumbs.showInterfaces": true,
    "breadcrumbs.showMethods": true,
    "breadcrumbs.showModules": true,
    "breadcrumbs.showObjects": true,
    "breadcrumbs.showPackages": true,
    "breadcrumbs.showProperties": true,
    "breadcrumbs.showStructs": true,
    "breadcrumbs.showVariables": true,
    // ======================================================================
    // 7. Workbench tabs and editor management
    // ----------------------------------------------------------------------
    // Goal: clean tab bar, fewer wrapped rows, predictable close buttons, and
    // no preview tabs so opened files stay stable.
    // ======================================================================
    "workbench.sideBar.location": "left",
    "workbench.statusBar.visible": true,
    "workbench.reduceMotion": "off",
    "workbench.editor.emptyWindowText": "off",
    // Open settings in JSON mode by default so advanced UI/CSS tuning is easier.
    "workbench.settings.useSplitJSON": false,
    "workbench.editor.enablePreview": false,
    "workbench.editor.showTabs": "multiple",
    "workbench.editor.pinnedTabsOnSeparateRow": false,
    "workbench.editor.pinnedTabSizing": "compact",
    "workbench.editor.tabSizing": "fit",
    "workbench.editor.wrapTabs": false,
    // Cleaner tabs: close button remains predictable; editor actions hidden until hover for reduced chrome.
    "workbench.editor.tabCloseButton": "right",
    "workbench.editor.alwaysShowEditorActions": false,
    "workbench.editor.showIcons": true,
    "workbench.editor.highlightModifiedTabs": true,
    "workbench.editor.labelFormat": "short",
    "workbench.editor.restoreViewState": true,
    "workbench.editor.closeOnFileDelete": true,
    "workbench.editor.decorations.colors": true,
    "workbench.editor.decorations.badges": true,
    "workbench.editor.focusRecentEditorAfterClose": true,
    "workbench.editor.revealIfOpen": true,
    "workbench.editor.closeEmptyGroups": true,
    "workbench.editor.splitSizing": "split",
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 10,
    "workbench.editor.limit.perEditorGroup": true,
    // ======================================================================
    // 8. Explorer / solution-view behavior
    // ======================================================================
    "workbench.tree.indent": 16,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.tree.enableStickyScroll": true,
    "workbench.tree.expandMode": "singleClick",
    "workbench.list.smoothScrolling": true,
    "workbench.list.keyboardNavigation": "highlight",
    "explorer.autoReveal": "focusNoScroll",
    "explorer.incrementalNaming": "smart",
    "explorer.confirmDragAndDrop": true,
    "explorer.confirmDelete": false,
    "explorer.confirmPasteNative": false,
    "explorer.compactFolders": false,
    "explorer.sortOrder": "type",
    "explorer.decorations.badges": true,
    "explorer.decorations.colors": true,
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.expand": false,
    "explorer.fileNesting.patterns": {
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lock, bun.lockb, .npmrc, .yarnrc.yml",
        "tsconfig.json": "tsconfig.*.json",
        "vite.config.*": "vitest.config.*, playwright.config.*, cypress.config.*",
        "next.config.*": "next-env.d.ts, middleware.*, instrumentation.*",
        "tailwind.config.*": "postcss.config.*, components.json",
        "eslint.config.*": ".eslintignore",
        "prettier.config.*": ".prettierignore",
        "README.md": "CHANGELOG.md, LICENSE, SECURITY.md, CODE_OF_CONDUCT.md, CONTRIBUTING.md",
        "Dockerfile": ".dockerignore, docker-compose*.yml, compose*.yml",
        ".env": ".env.*, !.env.example"
    },
    // ======================================================================
    // 9. Search, files, excludes, and performance
    // ======================================================================
    "search.searchOnType": false,
    // Search waits for Enter, reducing UI churn on large workspaces.
    "search.showLineNumbers": true,
    "search.decorations.colors": true,
    "search.collapseResults": "auto",
    "search.smartCase": true,
    "search.useIgnoreFiles": true,
    "search.useGlobalIgnoreFiles": true,
    "search.quickOpen.includeSymbols": true,
    "search.searchEditor.doubleClickBehaviour": "goToLocation",
    "files.autoSave": "onFocusChange",
    "files.autoSaveDelay": 1000,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "files.insertFinalNewline": true,
    "files.eol": "\n",
    "files.simpleDialog.enable": false,
    "files.hotExit": "onExitAndWindowClose",
    "files.restoreUndoStack": true,
    "search.exclude": {
        "**/.angular": true,
        "**/.svelte-kit": true,
        "**/.astro": true,
        "**/.output": true,
        "**/.serverless": true,
        "**/.pnpm-store": true,
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/.venv": true,
        "**/venv": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.next": true,
        "**/.nuxt": true,
        "**/.turbo": true,
        "**/.cache": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/.tox": true,
        "**/.parcel-cache": true
    },
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/dist": true,
        "**/build": true,
        "**/.vscode": false,
        "**/.idea": true,
        "**/*.log": true,
        "**/coverage": true,
        ".pytest_cache": true,
        "__pycache__": true,
        "**/__pycache__": true,
        "**/.next": true,
        "**/.nuxt": true,
        "**/.turbo": true,
        "**/.cache": true,
        "**/.mypy_cache": true,
        "**/.ruff_cache": true,
        "**/.tox": true,
        "**/.parcel-cache": true
    },
    "files.watcherExclude": {
        "**/.angular/**": true,
        "**/.svelte-kit/**": true,
        "**/.astro/**": true,
        "**/.output/**": true,
        "**/.serverless/**": true,
        "**/.pnpm-store/**": true,
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/.git/**": true,
        "**/*.log": true,
        "**/__pycache__/**": true,
        "**/.pytest_cache/**": true,
        "**/.venv/**": true,
        "**/venv/**": true,
        "**/.next/**": true,
        "**/.nuxt/**": true,
        "**/.turbo/**": true,
        "**/.cache/**": true,
        "**/.mypy_cache/**": true,
        "**/.ruff_cache/**": true,
        "**/.tox/**": true,
        "**/.parcel-cache/**": true,
        "**/coverage/**": true
    },
    // ======================================================================
    // 10. Terminal
    // ======================================================================
    "terminal.integrated.minimumContrastRatio": 1,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.scrollback": 20000,
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "terminal.integrated.enablePersistentSessions": true,
    "terminal.integrated.persistentSessionReviveProcess": "onExitAndWindowClose",
    "terminal.integrated.fontFamily": "'IBM Plex Mono', 'JetBrains Mono', 'FiraCode Nerd Font Mono', 'Monaspace Neon', 'Fira Code', 'Menlo', 'Monaco', monospace",
    "terminal.integrated.fontSize": 17,
    "terminal.integrated.fontWeight": "400",
    "terminal.integrated.lineHeight": 1.45,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorWidth": 2,
    "terminal.integrated.customGlyphs": true,
    "terminal.integrated.tabs.enabled": true,
    "terminal.integrated.tabs.hideCondition": "singleTerminal",
    "terminal.integrated.mouseWheelScrollSensitivity": 3,
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.gpuAcceleration": "on",
    // ======================================================================
    // 11. Git, diff, merge, AI tools
    // ======================================================================
    "git.decorations.enabled": true,
    "git.autorefresh": true,
    "git.autoRepositoryDetection": "subFolders",
    "git.detectSubmodules": true,
    "git.showPushSuccessNotification": true,
    "git.autofetch": true,
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.openRepositoryInParentFolders": "always",
    "git.pruneOnFetch": true,
    "git.branchProtectionPrompt": "alwaysPrompt",
    "scm.defaultViewMode": "tree",
    "scm.showHistoryGraph": true,
    "scm.alwaysShowRepositories": true,
    "scm.diffDecorations": "all",
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.renderSideBySide": true,
    "diffEditor.wordWrap": "on",
    "diffEditor.hideUnchangedRegions.enabled": false,
    "diffEditor.showMoves": true,
    "diffEditor.diffAlgorithm": "advanced",
    "diffEditor.renderIndicators": true,
    "diffEditor.codeLens": true,
    "mergeEditor.enabled": true,
    "github.copilot.enable": {
        "*": true,
        "plaintext": true,
        "markdown": true,
        "scminput": true,
        "python": true,
        "csharp": true
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "chat.agent.maxRequests": 50,
    "chat.detectParticipant.enabled": false,
    "chat.viewSessions.orientation": "stacked",
    "claudeCode.preferredLocation": "panel",
    // ======================================================================
    // 12. Problems panel
    // ======================================================================
    "problems.showWarnings": true,
    "problems.showInfos": true,
    "problems.showCurrentInStatus": true,
    "problems.decorations.enabled": true,
    "problems.autoReveal": false,
    "problems.sortOrder": "severity",
    // ======================================================================
    // 13. Theme-Specific Color Customizations
    // ======================================================================
    // ======================================================================
    // 14. Custom UI stylesheet
    // ----------------------------------------------------------------------
    // CSS selectors belong here, not in workbench.colorCustomizations.
    // This section is the main UI/UX upgrade: rounded panels, softer borders,
    // calmer shadows, floating activity bar, polished command palette, and
    // modern editor/terminal cards. Requires the Custom UI Style extension.
    // The editor scrollbar CSS is scoped to .part.editor .monaco-editor so
    // it does not enlarge Terminal, Explorer, Search, Problems, or other panels.
    //
    // ANIMATIONS: @keyframes are defined inline here so no separate CSS file
    // is needed. We only preserve hierarchy-clarifying interaction animations
    // in accordance with the design system.
    // ======================================================================
    "custom-ui-style.stylesheet": {
        ".monaco-workbench": {
            "--nb-panel-radius": "24px",
            "--nb-widget-radius": "14px",
            "--nb-input-radius": "12px",
            "--nb-item-radius": "6px",
            "--nb-panel-gap": "6px",
            "--nb-panel-top": "6px",
            "--nb-bg-canvas": "var(--vscode-workbench-background)",
            "--nb-bg-surface": "color-mix(in srgb, var(--vscode-sideBar-background) 85%, var(--vscode-editor-background) 15%)",
            // Timing tokens
            "--nb-motion-fast": "100ms",
            "--nb-motion-base": "160ms",
            "--nb-motion-slow": "240ms",
            "--nb-motion-page": "360ms",
            // Easing presets
            "--nb-ease-standard": "cubic-bezier(0.2, 0, 0, 1)",
            "--nb-ease-out": "cubic-bezier(0, 0, 0.2, 1)",
            "--nb-ease-in-out": "cubic-bezier(0.4, 0, 0.2, 1)",
            "background-color": "var(--nb-bg-canvas) !important",
            "font-family": "'Bear Sans UI', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important"
        },
        ".part.titlebar": {
            "background-color": "color-mix(in srgb, var(--vscode-titleBar-activeBackground) 70%, transparent) !important",
            "backdrop-filter": "blur(12px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(12px) saturate(150%) !important",
            "border-bottom": "1px solid color-mix(in srgb, var(--vscode-titleBar-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.2))) 50%, var(--vscode-foreground) 10%) !important",
            "transition": "background-color var(--nb-motion-slow) var(--nb-ease-standard), border-color var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".part.statusbar": {
            "background-color": "color-mix(in srgb, var(--vscode-statusBar-background) 70%, transparent) !important",
            "backdrop-filter": "blur(12px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(12px) saturate(150%) !important",
            "border-top": "1px solid color-mix(in srgb, var(--vscode-statusBar-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.2))) 50%, var(--vscode-foreground) 10%) !important",
            "transition": "background-color var(--nb-motion-slow) var(--nb-ease-standard), border-color var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".part.sidebar": {
            "font-family": "'Bear Sans UI', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important",
            "border-radius": "var(--nb-panel-radius) !important",
            "background-color": "color-mix(in srgb, var(--vscode-sideBar-background) 70%, transparent) !important",
            "backdrop-filter": "blur(8px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(8px) saturate(150%) !important",
            "border-right": "1px solid color-mix(in srgb, var(--vscode-sideBar-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 60%, var(--vscode-foreground) 40%) !important",
            "box-shadow": "0 8px 32px 0 rgba(0, 0, 0, 0.2) !important",
            "transition": "background var(--nb-motion-slow) var(--nb-ease-standard), border-color var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".part.sidebar .composite.title": {
            "padding": "8px 20px 0 0 !important"
        },
        ".part.sidebar .title-label h2": {
            "font-family": "'Bear Sans UI Heading', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif !important",
            "font-size": "12px !important",
            "font-weight": "700 !important",
            "text-transform": "uppercase !important",
            "letter-spacing": "1px !important"
        },
        ".part.sidebar .monaco-list-row": {
            "border-radius": "var(--nb-item-radius) !important",
            "margin-left": "4px !important",
            "margin-right": "4px !important",
            "width": "calc(100% - 8px) !important",
            "transition": "background var(--nb-motion-base) var(--nb-ease-standard), box-shadow var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".part.sidebar .monaco-list-row.focused": {
            "outline": "none !important",
            "box-shadow": "inset 0 0 0 1px color-mix(in srgb, var(--vscode-list-focusOutline, var(--vscode-focusBorder, rgba(128, 128, 128, 0.3))) 60%, transparent) !important"
        },
        ".part.sidebar .monaco-list-row:hover": {
            "outline": "none !important"
        },
        ".part.editor": {
            "margin": "var(--nb-panel-top) var(--nb-panel-gap) var(--nb-panel-gap) var(--nb-panel-gap) !important",
            "border-radius": "var(--nb-panel-radius) !important",
            "overflow": "hidden !important",
            "max-height": "calc(100% - var(--nb-panel-top) - var(--nb-panel-gap) - 2px) !important",
            "background-color": "color-mix(in srgb, var(--vscode-editor-background) 90%, transparent) !important",
            "backdrop-filter": "blur(30px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(30px) saturate(150%) !important",
            "border-top": "1.5px solid color-mix(in srgb, var(--vscode-editorGroup-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 80%, var(--vscode-foreground) 20%) !important",
            "border-left": "1.5px solid color-mix(in srgb, var(--vscode-editorGroup-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 75%, var(--vscode-foreground) 25%) !important",
            "border-bottom": "1px solid color-mix(in srgb, var(--vscode-editorGroup-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 60%, var(--vscode-foreground) 40%) !important",
            "border-right": "1px solid color-mix(in srgb, var(--vscode-editorGroup-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 60%, var(--vscode-foreground) 40%) !important",
            "box-shadow": "0 8px 32px 0 rgba(0, 0, 0, 0.2) !important",
            "transition": "margin var(--nb-motion-slow) var(--nb-ease-standard), border-color var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".tab": {
            "position": "relative !important",
            "border-radius": "var(--nb-item-radius) !important",
            "background-color": "color-mix(in srgb, var(--vscode-tab-inactiveBackground) 20%, transparent) !important",
            "backdrop-filter": "blur(20px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(20px) saturate(150%) !important",
            "border": "1px solid color-mix(in srgb, var(--vscode-tab-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 70%, var(--vscode-foreground) 30%) !important",
            "margin": "2px 2px !important",
            "box-sizing": "border-box !important",
            "transition": "background-color var(--nb-motion-base) var(--nb-ease-standard), border-color var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".tab.active": {
            "background-color": "color-mix(in srgb, var(--vscode-tab-activeBackground) 50%, transparent) !important",
            "border": "1px solid color-mix(in srgb, var(--vscode-tab-activeBorder, var(--vscode-foreground)) 80%, transparent) !important",
            "box-shadow": "0 2px 8px rgba(0, 0, 0, 0.15), inset 0 1px 0.5px rgba(255, 255, 255, 0.15) !important"
        },
        ".tab::after": {
            "content": "'' !important",
            "position": "absolute !important",
            "bottom": "0 !important",
            "left": "50% !important",
            "width": "0 !important",
            "height": "2px !important",
            "background-color": "var(--vscode-tab-activeBorder, var(--vscode-foreground)) !important",
            "transition": "width var(--nb-motion-base) var(--nb-ease-standard), left var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".tab.active::after": {
            "left": "15% !important",
            "width": "70% !important"
        },
        ".tab:hover .label-name": {
            "text-shadow": "0 0 5px color-mix(in srgb, var(--vscode-tab-activeForeground) 40%, transparent) !important",
            "transition": "text-shadow var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".tab:active": {
            "transform": "scale(0.96) !important",
            "opacity": "0.9 !important",
            "transition": "transform var(--nb-motion-fast) var(--nb-ease-standard), opacity var(--nb-motion-fast) var(--nb-ease-standard) !important"
        },
        ".part.panel.bottom": {
            "border-radius": "var(--nb-panel-radius) !important",
            "background-color": "color-mix(in srgb, var(--vscode-panel-background) 40%, transparent) !important",
            "backdrop-filter": "blur(40px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(40px) saturate(150%) !important",
            "border-top": "1px solid color-mix(in srgb, var(--vscode-panel-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 60%, var(--vscode-foreground) 40%) !important",
            "transition": "background-color var(--nb-motion-slow) var(--nb-ease-standard), border-color var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".part.panel.bottom > .content": {
            "border-radius": "0 0 calc(var(--nb-panel-radius) - var(--nb-panel-gap)) calc(var(--nb-panel-radius) - var(--nb-panel-gap)) !important",
            "overflow": "hidden !important"
        },
        ".part.activitybar": {
            "background": "var(--vscode-workbench-background) !important",
            "margin": "var(--nb-panel-top) 0 var(--nb-panel-gap) 0",
            "overflow": "visible !important"
        },
        ".part.activitybar .composite-bar": {
            "background": "color-mix(in srgb, var(--vscode-activityBar-background, var(--vscode-sideBar-background)) 40%, transparent) !important",
            "backdrop-filter": "blur(40px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(40px) saturate(150%) !important",
            "border-radius": "9999px",
            "overflow": "hidden !important",
            "width": "calc(100% - 8px) !important",
            "margin-left": "auto !important",
            "margin-right": "auto !important",
            "padding": "8px 3px !important",
            "box-sizing": "border-box !important",
            "display": "flex !important",
            "flex-direction": "column !important",
            "align-items": "center !important",
            "border": "1.5px solid color-mix(in srgb, var(--vscode-activityBar-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 70%, var(--vscode-foreground) 30%) !important",
            "box-shadow": "0 4px 16px rgba(0, 0, 0, 0.15) !important",
            "transition": "background-color var(--nb-motion-slow) var(--nb-ease-standard), border-color var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".part.activitybar .action-item .active-item-indicator": {
            "display": "none !important"
        },
        ".part.activitybar .action-item .action-label": {
            "transition": "background var(--nb-motion-base) var(--nb-ease-standard), box-shadow var(--nb-motion-base) var(--nb-ease-standard), transform var(--nb-motion-fast) var(--nb-ease-standard) !important"
        },
        ".part.activitybar .action-item.checked .action-label": {
            "background": "linear-gradient(135deg, color-mix(in srgb, var(--vscode-activityBar-activeBackground, rgba(128, 128, 128, 0.2)) 80%, transparent), color-mix(in srgb, var(--vscode-activityBar-activeBackground, rgba(128, 128, 128, 0.2)) 40%, transparent)) !important",
            "border-radius": "50% !important",
            "box-shadow": "inset 0 1px 2px color-mix(in srgb, var(--vscode-widget-border) 60%, transparent), 0 2px 6px rgba(0,0,0,0.15) !important"
        },
        ".part.activitybar .action-item:active": {
            "transform": "scale(0.9) !important",
            "transition": "transform var(--nb-motion-fast) var(--nb-ease-standard) !important"
        },
        ".part.auxiliarybar": {
            "border-radius": "var(--nb-panel-radius) !important",
            "background-color": "color-mix(in srgb, var(--vscode-sideBar-background) 40%, transparent) !important",
            "backdrop-filter": "blur(40px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(40px) saturate(150%) !important",
            "border-left": "1px solid color-mix(in srgb, var(--vscode-sideBar-border, var(--vscode-widget-border, rgba(128, 128, 128, 0.4))) 60%, var(--vscode-foreground) 40%) !important",
            "box-shadow": "0 8px 32px 0 rgba(0, 0, 0, 0.2) !important",
            "transition": "background-color var(--nb-motion-slow) var(--nb-ease-standard), border-color var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".quick-input-widget": {
            "top": "50% !important",
            "transform": "translateY(-50%) !important",
            "border-radius": "var(--nb-widget-radius) !important",
            "overflow": "hidden !important",
            "background-color": "color-mix(in srgb, var(--vscode-quickInput-background, var(--vscode-sideBar-background)) 40%, transparent) !important",
            "backdrop-filter": "blur(48px) saturate(200%) !important",
            "-webkit-backdrop-filter": "blur(48px) saturate(200%) !important",
            "border": "1px solid color-mix(in srgb, var(--vscode-widget-border, rgba(128, 128, 128, 0.4)) 50%, rgba(255, 255, 255, 0.08)) !important",
            "box-shadow": "0 30px 90px rgba(0, 0, 0, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.25), 0 0 0 100vw rgba(0, 0, 0, 0.2) !important",
            "animation": "nb-spotlight var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".quick-input-widget .monaco-list-row": {
            "border-radius": "var(--nb-item-radius) !important",
            "margin-left": "4px !important",
            "margin-right": "4px !important",
            "width": "calc(100% - 8px) !important",
            "transition": "background var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".quick-input-widget .monaco-list-row.focused": {
            "outline": "none !important",
            "box-shadow": "inset 0 0 0 1px color-mix(in srgb, var(--vscode-list-focusOutline, var(--vscode-focusBorder, rgba(128, 128, 128, 0.3))) 60%, transparent) !important"
        },
        ".notification-toast": {
            "border-radius": "var(--nb-widget-radius) !important",
            "overflow": "hidden !important",
            "background-color": "color-mix(in srgb, var(--vscode-notifications-background, var(--vscode-sideBar-background)) 40%, transparent) !important",
            "backdrop-filter": "blur(48px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(48px) saturate(150%) !important",
            "border": "1px solid color-mix(in srgb, var(--vscode-widget-border, rgba(128, 128, 128, 0.4)) 50%, rgba(255, 255, 255, 0.08)) !important",
            "box-shadow": "0 8px 32px rgba(0, 0, 0, 0.25), inset 0 1px 1px rgba(255, 255, 255, 0.25) !important",
            "animation": "nb-notify var(--nb-motion-page) var(--nb-ease-standard) !important"
        },
        ".notifications-center": {
            "border-radius": "var(--nb-widget-radius) !important",
            "overflow": "hidden !important",
            "background-color": "color-mix(in srgb, var(--vscode-notifications-background, var(--vscode-sideBar-background)) 40%, transparent) !important",
            "backdrop-filter": "blur(48px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(48px) saturate(150%) !important",
            "border": "1px solid color-mix(in srgb, var(--vscode-widget-border, rgba(128, 128, 128, 0.4)) 50%, rgba(255, 255, 255, 0.08)) !important",
            "box-shadow": "0 16px 48px rgba(0, 0, 0, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.25) !important",
            "animation": "nb-emerge var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".monaco-inputbox": {
            "border-radius": "var(--nb-input-radius) !important",
            "transition": "box-shadow var(--nb-motion-base) var(--nb-ease-standard), border-color var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".monaco-inputbox.focused": {
            "box-shadow": "0 0 0 3px color-mix(in srgb, var(--vscode-focusBorder) 30%, transparent) !important"
        },
        ".monaco-list-row": {
            "transition": "background-color var(--nb-motion-base) var(--nb-ease-standard), box-shadow var(--nb-motion-base) var(--nb-ease-standard), transform var(--nb-motion-fast) var(--nb-ease-standard) !important"
        },
        ".monaco-list-row:active": {
            "transform": "scale(0.96) !important",
            "opacity": "0.9 !important"
        },
        ".monaco-button": {
            "border-radius": "var(--nb-input-radius) !important",
            "transition": "background-color var(--nb-motion-base) var(--nb-ease-standard), transform var(--nb-motion-fast) var(--nb-ease-standard) !important"
        },
        ".monaco-button:active": {
            "transform": "scale(0.96) !important",
            "opacity": "0.9 !important",
            "transition": "transform var(--nb-motion-fast) var(--nb-ease-standard), opacity var(--nb-motion-fast) var(--nb-ease-standard) !important"
        },
        ".action-label": {
            "transition": "transform var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".action-label:hover": {
            "transform": "scale(1.1) !important"
        },
        ".action-label:active": {
            "transform": "scale(0.96) !important",
            "opacity": "0.9 !important"
        },
        ".monaco-scrollable-element > .scrollbar > .slider": {
            "background": "color-mix(in srgb, var(--vscode-scrollbarSlider-background) 80%, transparent) !important",
            "border-radius": "10px !important",
            "transition": "opacity var(--nb-motion-slow) var(--nb-ease-standard), transform var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".monaco-scrollable-element > .scrollbar.vertical > .slider:hover": {
            "transform": "scaleX(1.3) !important"
        },
        ".monaco-scrollable-element > .scrollbar.horizontal > .slider:hover": {
            "transform": "scaleY(1.3) !important"
        },
        ".scm-editor": {
            "border-radius": "var(--nb-input-radius) !important",
            "overflow": "hidden !important"
        },
        ".search-widget .replace-input .monaco-findInput, .search-widget .search-container .monaco-findInput, .extensions-search-container .suggest-input-container": {
            "border-radius": "var(--nb-input-radius) !important",
            "overflow": "hidden !important"
        },
        ".scm-input": {
            "border-radius": "var(--nb-input-radius) !important",
            "overflow": "hidden !important"
        },
        ".scrollbar .slider": {
            "border-radius": "9999px !important"
        },
        ".monaco-dialog-box": {
            "border-radius": "var(--nb-widget-radius) !important",
            "overflow": "hidden !important",
            "background-color": "color-mix(in srgb, var(--vscode-sideBar-background) 40%, transparent) !important",
            "backdrop-filter": "blur(48px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(48px) saturate(150%) !important",
            "border": "1px solid color-mix(in srgb, var(--vscode-widget-border, rgba(128, 128, 128, 0.4)) 50%, rgba(255, 255, 255, 0.08)) !important",
            "box-shadow": "0 32px 96px rgba(0, 0, 0, 0.4), inset 0 1px 1px rgba(255, 255, 255, 0.25) !important",
            "animation": "nb-emerge var(--nb-motion-slow) var(--nb-ease-standard) !important"
        },
        ".monaco-dialog-box .dialog-buttons .monaco-button": {
            "border-radius": "var(--nb-input-radius) !important"
        },
        ".monaco-breadcrumbs": {
            "opacity": "0.75 !important",
            "transition": "opacity var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".monaco-breadcrumbs:hover": {
            "opacity": "1 !important"
        },
        ".tab .tab-actions": {
            "opacity": "0 !important",
            "transition": "opacity var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".tab:hover .tab-actions, .tab.active .tab-actions": {
            "opacity": "1 !important"
        },
        ".minimap canvas": {
            "opacity": "0.7 !important",
            "transition": "opacity var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".minimap:hover canvas": {
            "opacity": "1 !important"
        },
        ".part.statusbar .statusbar-item-label, .part.statusbar .codicon": {
            "opacity": "0.65 !important",
            "transition": "opacity var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".part.statusbar:hover .statusbar-item-label, .part.statusbar:hover .codicon": {
            "opacity": "1 !important"
        },
        ".monaco-icon-label.file-icon::before": {
            "filter": "drop-shadow(0 0 2.5px currentColor) !important",
            "opacity": "1 !important"
        },
        ".command-center-center": {
            "border-radius": "9999px !important",
            "overflow": "hidden !important",
            "border": "1.5px solid color-mix(in srgb, var(--vscode-widget-border, rgba(128, 128, 128, 0.4)) 70%, var(--vscode-foreground) 30%) !important",
            "background-color": "color-mix(in srgb, var(--vscode-sideBar-background) 30%, transparent) !important",
            "backdrop-filter": "blur(20px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(20px) saturate(150%) !important",
            "box-shadow": "0 2px 8px rgba(0,0,0,0.1) !important",
            "transition": "border-color var(--nb-motion-base) var(--nb-ease-standard), background-color var(--nb-motion-base) var(--nb-ease-standard), box-shadow var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".command-center-center:hover": {
            "border-color": "color-mix(in srgb, var(--vscode-commandCenter-activeBorder, var(--vscode-focusBorder)) 60%, var(--vscode-foreground) 40%) !important",
            "background-color": "color-mix(in srgb, var(--vscode-sideBar-background) 50%, transparent) !important",
            "box-shadow": "0 4px 16px rgba(0,0,0,0.15) !important"
        },
        ".command-center-center:active": {
            "transform": "scale(0.96) !important",
            "transition": "transform var(--nb-motion-fast) var(--nb-ease-standard) !important"
        },
        ".command-center-center *": {
            "border-radius": "9999px !important"
        },
        ".monaco-count-badge": {
            "border-radius": "9999px !important",
            "padding": "0 6px !important",
            "min-height": "16px !important",
            "line-height": "16px !important",
            "font-size": "12px !important"
        },
        ".sticky-widget": {
            "box-shadow": "0 4px 8px -2px rgba(0,0,0,0.2) !important"
        },
        ".chat-input-container, .interactive-input-part": {
            "border-radius": "var(--nb-widget-radius) !important",
            "overflow": "visible !important",
            "background-color": "color-mix(in srgb, var(--vscode-sideBar-background) 40%, transparent) !important",
            "backdrop-filter": "blur(24px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(24px) saturate(150%) !important",
            "border": "1.5px solid color-mix(in srgb, var(--vscode-widget-border, rgba(128, 128, 128, 0.4)) 70%, var(--vscode-foreground) 30%) !important"
        },
        ".notebookOverlay": {
            "border-radius": "0 0 var(--nb-panel-radius) var(--nb-panel-radius) !important"
        },
        ".notifications-toasts": {
            "margin-right": "var(--nb-panel-gap) !important",
            "margin-bottom": "var(--nb-panel-gap) !important"
        },
        ".monaco-hover": {
            "border-radius": "var(--nb-input-radius) !important",
            "background-color": "color-mix(in srgb, var(--vscode-editorHoverWidget-background, var(--vscode-sideBar-background)) 50%, transparent) !important",
            "backdrop-filter": "blur(30px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(30px) saturate(150%) !important",
            "border": "1px solid color-mix(in srgb, var(--vscode-widget-border, rgba(128, 128, 128, 0.4)) 50%, rgba(255, 255, 255, 0.08)) !important",
            "box-shadow": "0 10px 30px rgba(0, 0, 0, 0.2), inset 0 1px 1px rgba(255, 255, 255, 0.2) !important",
            "overflow": "hidden !important",
            "animation": "nb-emerge var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        ".suggest-widget": {
            "border-radius": "var(--nb-widget-radius) !important",
            "overflow": "hidden !important",
            "background-color": "color-mix(in srgb, var(--vscode-editorSuggestWidget-background) 70%, transparent) !important",
            "backdrop-filter": "blur(30px) saturate(150%) !important",
            "-webkit-backdrop-filter": "blur(30px) saturate(150%) !important",
            "border": "1px solid color-mix(in srgb, var(--vscode-widget-border, rgba(128, 128, 128, 0.4)) 50%, rgba(255, 255, 255, 0.08)) !important",
            "box-shadow": "0 12px 36px rgba(0, 0, 0, 0.25), inset 0 1px 1px rgba(255, 255, 255, 0.2) !important",
            "animation": "nb-emerge var(--nb-motion-base) var(--nb-ease-standard) !important"
        },
        "@keyframes nb-emerge": {
            "from": {
                "opacity": "0",
                "transform": "translateY(-4px) scale(0.98)"
            },
            "to": {
                "opacity": "1",
                "transform": "translateY(0) scale(1)"
            }
        },
        "@keyframes nb-notify": {
            "from": {
                "opacity": "0",
                "transform": "translateX(20px) scale(0.96)"
            },
            "to": {
                "opacity": "1",
                "transform": "translateX(0) scale(1)"
            }
        },
        "@keyframes nb-spotlight": {
            "from": {
                "opacity": "0",
                "transform": "translateY(-12px) scale(0.98)"
            },
            "to": {
                "opacity": "1",
                "transform": "translateY(0) scale(1)"
            }
        },
        "@media (prefers-reduced-motion: reduce)": {
            ".monaco-workbench": {
                "--nb-motion-fast": "0ms !important",
                "--nb-motion-base": "0ms !important",
                "--nb-motion-slow": "0ms !important",
                "--nb-motion-page": "0ms !important"
            },
            "*": {
                "animation-duration": "0s !important",
                "animation-delay": "0s !important",
                "transition-duration": "0s !important",
                "transition-delay": "0s !important",
                "transform": "none !important"
            }
        }
    },
    // ======================================================================
    // ======================================================================
    // 15. Language-specific settings
    // ======================================================================
    "[javascript]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[typescript]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[typescriptreact]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },
    "[python]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },
    "[html]": {
        "editor.tabSize": 2
    },
    "[css]": {
        "editor.tabSize": 2
    },
    "[json]": {
        "editor.tabSize": 4
    },
    "[jsonc]": {
        "editor.tabSize": 4
    },
    "workbench.editor.tabActionLocation": "right",
    "workbench.colorTheme": "Note Book Dark"
}
